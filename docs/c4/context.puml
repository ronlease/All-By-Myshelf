@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

title System Context — All By Myshelf

Person(user, "Owner", "Single authenticated user managing their record collection")

System(app, "All By Myshelf", "Personal collection dashboard that stores and displays a local copy of a Discogs collection")

System_Ext(auth0, "Auth0", "Identity provider. Issues JWT tokens for the single user.")
System_Ext(discogs, "Discogs API", "Source of truth for the user's vinyl record collection. Queried during background sync.")

Rel(user, app, "Views collection, triggers sync", "HTTPS")
Rel(app, auth0, "Validates JWT tokens", "HTTPS/OIDC")
Rel(user, auth0, "Authenticates", "HTTPS/OIDC")
Rel(app, discogs, "Fetches collection data using personal access token", "HTTPS/JSON")

@enduml
