@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title Container Diagram — All By Myshelf

Person(user, "Owner", "Single authenticated user")

System_Ext(auth0, "Auth0", "Identity provider. Issues and validates JWT tokens.")
System_Ext(discogs, "Discogs API", "External vinyl record collection API. Rate-limited; returns collection data in paginated responses.")
System_Ext(hardcover, "Hardcover API", "External read-books API. GraphQL endpoint returning books with metadata.")

System_Boundary(app, "All By Myshelf") {
    Container(web, "Web App", "Angular 21, standalone components, Angular Material", "Collection dashboard with global shell toolbar. Displays paginated records and books, recently added releases, collection maintenance view, random picker, store finder, and collection statistics.")

    Container(api, "API", "ASP.NET Core 10 Web API", "Serves local collections via GET /api/v1/releases and /api/v1/books. Provides maintenance, recently added, random, statistics, and feature-flag endpoints. Accepts POST /api/v1/sync and /api/v1/books/sync to start background syncs. Validates Auth0 JWTs on all requests.")

    Container(discogsSyncWorker, "Discogs Sync Worker", "BackgroundService inside AllByMyshelf.Api", "Fetches all releases from the Discogs API with detail and marketplace pricing, respects rate limits (retries on HTTP 429), and upserts results into the database. Prevents concurrent runs.")

    Container(hardcoverSyncWorker, "Hardcover Sync Worker", "BackgroundService inside AllByMyshelf.Api", "Fetches read books from the Hardcover GraphQL API, extracts genre from cached_tags, and upserts results into the database. Prevents concurrent runs.")

    ContainerDb(db, "Collection Database", "PostgreSQL 17", "Stores local copies of Discogs releases (with pricing, artwork, genre, AddedAt timestamp) and Hardcover books (with author, genre, cover art).")
}

Rel(user, web, "Uses", "HTTPS")
Rel(web, auth0, "Redirects for login, receives JWT", "HTTPS/OIDC")
Rel(web, api, "REST API calls with Bearer JWT", "HTTPS/JSON")
Rel(api, auth0, "Validates JWT on each request", "HTTPS/OIDC")
Rel(api, discogsSyncWorker, "Enqueues sync job on POST /api/v1/sync", "In-process")
Rel(api, hardcoverSyncWorker, "Enqueues sync job on POST /api/v1/books/sync", "In-process")
Rel(discogsSyncWorker, discogs, "Fetches paginated collection, release detail, and marketplace stats", "HTTPS/JSON")
Rel(hardcoverSyncWorker, hardcover, "Fetches read books via GraphQL", "HTTPS/GraphQL")
Rel(discogsSyncWorker, db, "Upserts releases", "EF Core / Npgsql")
Rel(hardcoverSyncWorker, db, "Upserts books", "EF Core / Npgsql")
Rel(api, db, "Queries releases and books", "EF Core / Npgsql")

@enduml
